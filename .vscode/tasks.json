    {
      "label": "Open HTML Report",
      "type": "shell",
      "command": "Start-Process",
      "args": [
        "${workspaceFolder}\\reports\\generated\\cucumber-report.html"
      ],
      "windows": {
        "command": "Start-Process",
        "args": [
          "${workspaceFolder}\\reports\\generated\\cucumber-report.html"
        ]
      },
      "linux": {
        "command": "xdg-open",
        "args": [
          "${workspaceFolder}/reports/generated/cucumber-report.html"
        ]
      },
      "osx": {
        "command": "open",
        "args": [
          "${workspaceFolder}/reports/generated/cucumber-report.html"
        ]
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Tests + Open Report",
      "dependsOrder": "sequence",
      "dependsOn": [
