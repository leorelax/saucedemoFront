{
  "name": "saucedemo-playwright-cucumber",
  "version": "1.0.0",
  "description": "Automated testing suite for SauceDemo using Playwright and Cucumber with TypeScript",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:sequential": "cross-env WORKERS=1 cucumber-js",
    "test:chrome": "cross-env BROWSER=chromium cucumber-js",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js",
    "test:headless": "cross-env HEADLESS=true cucumber-js",
    "test:headed": "cross-env HEADLESS=false cucumber-js",
    "test:login": "cross-env WORKERS=1 cucumber-js --tags '@login'",
    "test:cart": "cross-env WORKERS=1 cucumber-js --tags '@cart'",
    "test:checkout": "cross-env WORKERS=1 cucumber-js --tags '@checkout'",
    "test:any": "node scripts/run-tagged-tests.js",
    "test:smoke": "cucumber-js --tags \"@smoke\"",
    "test:critical": "cucumber-js --tags \"@critical\"",
    "test:positive": "cucumber-js --tags \"@positive\"",
    "test:negative": "cucumber-js --tags \"@negative\"",
    "test:regression": "cucumber-js --tags \"not @skip\"",
    "env": "node scripts/set-environment.js",
    "env:dev": "node scripts/set-environment.js dev",
    "env:qa": "node scripts/set-environment.js qa",
    "env:prod": "node scripts/set-environment.js prod",
    "report": "node scripts/generate-report.js",
    "test:report": "node scripts/run-tests-with-report.js",
    "clean": "rimraf reports/screenshots reports/generated",
    "lint": "eslint src/ steps/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"steps/**/*.ts\" \"src/features/**/*.feature\""
  },
  "keywords": [
    "playwright",
    "cucumber",
    "typescript",
    "automation",
    "testing",
    "e2e",
    "saucedemo",
    "page-object-model"
  ],
  "author": "J.V.",
  "license": "OK",
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.42.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "cross-env": "^7.0.3",
    "cucumber-html-reporter": "^7.1.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "fs-extra": "^11.2.0",
    "multiple-cucumber-html-reporter": "^3.6.2",
    "playwright": "^1.42.1",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "winston": "^3.11.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
